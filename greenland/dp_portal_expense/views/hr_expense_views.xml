<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom Search View for Vendor Selection (filters to Vendors only) -->
    <record id="res_partner_vendor_search_view" model="ir.ui.view">
        <field name="name">res.partner.vendor.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Search Vendors">
                <field name="name"/>
                <field name="vat"/>
                <field name="phone"/>
                <filter string="Vendors Only" name="vendor_filter" 
                        domain="[('x_studio_contact_type', '=', 'Vendor'), ('is_company', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Contact Type" name="group_contact_type" context="{'group_by': 'x_studio_contact_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Custom Tree View for Vendor Selection Popup -->
    <record id="res_partner_vendor_tree_view" model="ir.ui.view">
        <field name="name">res.partner.vendor.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Vendors">
                <field name="name"/>
                <field name="x_studio_contact_type"/>
                <field name="vat"/>
                <field name="phone"/>
            </tree>
        </field>
    </record>

    <record id="hr_expense_form_inherit" model="ir.ui.view">
        <field name="name">hr.expense.form.inherit</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_id']" position="after">
                <field name="reference" string="Invoice/Bill #" placeholder="e.g., INV-2025-001"/>
                <field name="vendor_vat"
                       string="VAT Number"
                       widget="vat_lookup"
                       placeholder="Type VAT number to search vendors..."/>
                <field name="vendor_id"
                       string="Vendor"
                       options="{'no_quick_create': True, 'no_create': True}"
                       context="{'res_partner_search_mode': 'supplier', 'default_is_company': True, 'default_x_studio_contact_type': 'Vendor', 'search_default_vendor_filter': 1, 'tree_view_ref': 'dp_portal_expense.res_partner_vendor_tree_view', 'search_view_ref': 'dp_portal_expense.res_partner_vendor_search_view'}"
                       domain="[('x_studio_contact_type', '=', 'Vendor'), ('is_company', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <record id="hr_expense_tree_inherit" model="ir.ui.view">
        <field name="name">hr.expense.tree.inherit</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.view_expenses_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="vendor_id" string="Vendor" optional="hide"/>
                <field name="vendor_vat" string="VAT Number" optional="hide"/>
                <field name="reference" string="Invoice #" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add Preview and Download buttons to Expense Sheet Form View -->
    <record id="view_hr_expense_sheet_form_buttons" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form.buttons</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_preview_report"
                    type="object"
                    string="Preview Report"
                    class="btn-primary"
                    help="Preview full expense report with attachments in browser"/>
                <button
                    name="action_download_report_only"
                    type="object"
                    string="Petty Cash Report"
                    class="btn-secondary"
                    icon="fa-download"
                    help="Download expense summary table only (no attachments)"/>
                <button
                    name="%(action_report_petty_cash_with_invoices)d"
                    type="action"
                    string="Petty Cash Report/Invoices"
                    class="btn-secondary"
                    icon="fa-download"
                    help="Download full expense report with invoices"/>
            </xpath>
            
            <!-- Update form view to show Report ID and Title separately -->
            <xpath expr="//field[@name='name']" position="replace">
                <field name="is_report_id_editable" invisible="1"/>
                <field name="report_reference" placeholder="Report ID" readonly="not is_report_id_editable" force_save="1"/>
            </xpath>
            <xpath expr="//field[@name='report_reference']" position="after">
                <field name="name" string="Report Title" placeholder="e.g. Trip to NY" readonly="not is_editable" required="1"/>
            </xpath>
        </field>
    </record>

    <!-- Customize Expense Sheet Tree View to show Report ID and Title separately -->
    <record id="view_hr_expense_sheet_tree_custom" model="ir.ui.view">
        <field name="name">hr.expense.sheet.tree.custom</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_tree"/>
        <field name="arch" type="xml">
            <!-- Replace the 'name' field to show it as 'Report ID' -->
            <xpath expr="//field[@name='name']" position="replace">
                <field name="report_reference" string="Report ID" readonly="1"/>
                <field name="name" string="Report Title" readonly="not is_editable"/>
            </xpath>
        </field>
    </record>
</odoo>

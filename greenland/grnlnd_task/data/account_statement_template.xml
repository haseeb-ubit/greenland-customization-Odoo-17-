<odoo>
    <data noupdate="1">
        <record id="email_template_custom_statement_of_account" model="mail.template">
            <field name="name">Statement of Account</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="email_from"> {{ (user.email_formatted or 'your_email@example.com') }} </field>
            <field name="partner_to">{{ object.id }}</field>
            <field name="lang">{{ object.lang }}</field>
            <field name="subject">Statement of Account - {{object.name}}</field> <!-- Subject with customer name -->
            <field name="description">Sent to customers with their latest statement of account</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear <t t-out="object.name" />,
                        <br /><br />
                        I hope this email finds you well. Please find attached your latest statement of account as of
                        <t t-esc="datetime.date.today()"/>
                        <br /><br />
                        This statement provides a detailed summary of your invoices and payments.
                        <br /><br />
                        If you have any questions or need further clarification, feel free to reach out.
                        <br /><br />
                        Thank you for your continued partnership.
                        <br /><br />
                        Best regards,
                        <br />
                        <t t-if="not is_html_empty(user.signature)">
                            <t t-out="user.signature"/>
                        </t>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>

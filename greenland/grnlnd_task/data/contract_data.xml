<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

<!-- Sequences for contract non hazardous -->
        <record id="seq_contract_non_hazardous" model="ir.sequence">
            <field name="name">Non Hazardous</field>
            <field name="code">non.hazardous.contract</field>
            <field name="prefix">Non-HZD-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequences for contract hazardous -->
        <record id="seq_contract_hazardous" model="ir.sequence">
            <field name="name">Hazardous</field>
            <field name="code">hazardous.contract</field>
            <field name="prefix">HZD-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
<odoo>
    <data>
        <record id="email_template_invoice_service_rendered" model="mail.template">
            <field name="name">Invoice for Services Rendered</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="email_from">{{ (object.invoice_user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="subject">Invoice for Services Rendered {{ object.name or 'n/a' }}</field>
            <field name="body_html" type="html">
                <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear <t t-out="object.partner_id.name" />,
                        <br/><br/>
                    <p>Thank you for choosing Greenland Environmental Services for your service needs. Please find attached the invoice for the recent services we provided. </p>
                    <p>We kindly request that payment be made at your earliest convenience. We appreciate your prompt attention to this matter and look forward to serving you again.</p>
                    <p>Best regards,<br/>
                    <br/>
                        <t t-if="not is_html_empty(user.signature)">
                            <t t-out="object.invoice_user_id.signature or ''"/>
                        </t></p></p>

                </div>
                </field>
            </field>
            <field name="auto_delete">True</field>
        </record>

    </data>
</odoo>

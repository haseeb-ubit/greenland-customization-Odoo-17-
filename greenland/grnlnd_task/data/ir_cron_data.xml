<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Cron Job for automatic state change of contracts -->
    <data noupdate="1">
        <record id="ir_cron_check_customer_doc_expiry_action" model="ir.cron">
            <field name="name">Customers Documents Expiry</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.customer_docs_expiry_check()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall">1</field>
        </record>
    </data>
</odoo>

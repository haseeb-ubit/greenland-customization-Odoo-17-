<odoo>
    <data>
        <record id="email_template_overdue_payment" model="mail.template">
            <field name="name">Urgent: Overdue Payment Reminder</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="email_from">{{ (object.invoice_user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="subject">Urgent: Overdue Payment Reminder</field>
            <field name="body_html" type="html">
                <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear <t t-out="object.partner_id.name" />,
                        <br/><br/>
                    <p>We hope this message receives your immediate attention. Our records indicate that payment for the attached invoice(s) is overdue. Attached, you will find your statement of account and the latest invoice(s) detailing the outstanding balance.</p>
                    <p>Please arrange payment promptly to avoid further complications. Your immediate attention to this matter is appreciated.</p>
                    <p>Best regards,<br/>
                    <br/>
                        <t t-if="not is_html_empty(object.invoice_user_id.signature)">
                            <t t-out="object.invoice_user_id.signature or ''"/>
                        </t></p></p>

                </div></field>
            </field>
            <field name="auto_delete">True</field>
        </record>

    </data>
</odoo>

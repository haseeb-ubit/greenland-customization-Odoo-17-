<odoo>
    <data>
        <record id="email_template_requested_document" model="mail.template">
            <field name="name">Requested Documents</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="subject">
                Requested Document: [Document_Type]
            </field>
            <field name="email_from">{{ (user.email_formatted or 'your_email@example.com') }}</field>
            <field name="partner_to">{{ object.id }}</field>
            <field name="lang">{{ object.lang }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear <t t-out="object.name" />,
                        <br/><br/>
                        I hope you're doing well. In response to your request, please find attached our latest [Document_Type]. We trust this meets your requirements.
                        <br/><br/>
                        If you need any further information or additional documents, please do not hesitate to contact us.
                        <br/><br/>
                        Best regards,
                        <br/>
                        <t t-if="not is_html_empty(user.signature)">
                            <t t-out="user.signature"/>
                        </t>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>

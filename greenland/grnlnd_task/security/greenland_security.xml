<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Your existing groups -->
    <record id="group_driver_access" model="res.groups">
            <field name="name">Driver Access</field>
            <field name="category_id" ref="base.module_category_services"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Group for drivers to access Greenland Services menu and their assigned Digital Service Tickets</field>
        </record>
        <record id="group_dispatcher_access" model="res.groups">
            <field name="name">Dispatcher Access</field>
            <field name="category_id" ref="base.module_category_services"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Group for dispatchers to create and manage Digital Service Tickets</field>
        </record>

        <!-- DRIVER RULE: Can access their assigned digital tickets (all states) -->
        <record id="rule_project_task_driver" model="ir.rule">
            <field name="name">Driver: Own Digital Tickets (All States)</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('grnlnd_task.group_driver_access'))]"/>
            <field name="domain_force">[
                ('driver_id', '=', user.employee_id.id),
                ('ticket_type', '=', 'digital')
            ]</field>
        </record>

        <!-- Admin users can see all service tickets -->
        <record id="rule_project_task_admin_all" model="ir.rule">
            <field name="name">Admin: See All Service Tickets</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Dispatchers can only see tickets they created (all states) -->
        <record id="rule_project_task_dispatcher_exclude_done" model="ir.rule">
            <field name="name">Dispatchers: Only Own Created Tickets (All States)</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('grnlnd_task.group_dispatcher_access'))]"/>
            <field name="domain_force">[
                ('create_uid', '=', user.id),
                ('ticket_type', '=', 'digital')
            ]</field>
        </record>
    <record id="rule_project_task_data_entry_manual" model="ir.rule">
        <field name="name">Data Entry: Manual Tickets Only</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('grnlnd_task.group_data_entry'))]"/>
        <field name="domain_force">[('ticket_type', '=', 'manual')]</field>
    </record>

    <!-- DISABLE Odoo's default global purchase order rule -->
    <record model="ir.rule" id="purchase.purchase_order_comp_rule">
        <field name="active" eval="False"/>
    </record>
    <!-- Purchase Users: Can read own POs + multi-company -->
    <record id="purchase_order_user_read_rule" model="ir.rule">
        <field name="name">Purchase Order: user read access (own or assigned + multi-company)</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="domain_force">
            [
                ('company_id', 'in', company_ids),
                '|',
                    ('create_uid', '=', user.id),
                    ('user_id', '=', user.id)
            ]
        </field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="groups" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>

    <record id="purchase_order_manager_all_rule" model="ir.rule">
        <field name="name">Purchase Order: manager full access + multi-company</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="groups" eval="[(4, ref('purchase.group_purchase_manager'))]"/>
    </record>
    <record id="purchase_order_line_user_read_rule" model="ir.rule">
        <field name="name">Purchase Order Line: user read access (own or assigned PO + multi-company)</field>
        <field name="model_id" ref="purchase.model_purchase_order_line"/>
        <field name="domain_force">
            [
                ('company_id', 'in', company_ids),
                '|',
                    ('order_id.create_uid', '=', user.id),
                    ('order_id.user_id', '=', user.id)
            ]
        </field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="groups" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>
    <record id="purchase_order_line_manager_all_rule" model="ir.rule">
        <field name="name">Purchase Order Line: manager full access + multi-company</field>
        <field name="model_id" ref="purchase.model_purchase_order_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="groups" eval="[(4, ref('purchase.group_purchase_manager'))]"/>
    </record>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add service ticket invoice field and make quantity readonly for service ticket invoices in draft state -->
    <record id="view_move_form_service_ticket_quantity_readonly" model="ir.ui.view">
        <field name="name">account.move.form.service.ticket.quantity.readonly</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add the service ticket invoice field (hidden) -->
            <xpath expr="//field[@name='move_type']" position="after">
                <field name="is_service_ticket_invoice" invisible="1"/>
            </xpath>
            <!-- Make quantity field readonly for service ticket invoices in draft state -->
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='quantity']" position="attributes">
                <attribute name="readonly">parent.is_service_ticket_invoice and parent.state == 'draft'</attribute>
            </xpath>
            <!-- Add Print Buttons to Header -->
            <xpath expr="//header" position="inside">
                <button name="%(account.account_invoices)d" string="Invoices" type="action" class="btn-secondary" icon="fa-download" groups="account.group_account_invoice"/>
                <button name="%(grnlnd_task.action_service_summary_report)d" string="Service Summary Report" type="action" class="btn-secondary" icon="fa-download" groups="account.group_account_invoice"/>
                <button name="%(grnlnd_task.action_report_invoice_and_summary)d" string="Invoice and Service Summary Report" type="action" class="btn-secondary" icon="fa-download" groups="account.group_account_invoice"/>
            </xpath>
        </field>
    </record>

    <!-- Unbind Standard Invoice Reports from the Print Menu & Set Filename -->
    <record id="account.account_invoices" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
        <field name="print_report_name">'%s - %s' % (object.partner_id.ref or object.partner_id.name, (object.name or '').replace('/', '∕'))</field>
    </record>
    <record id="account.account_invoices_without_payment" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_header_template">
        <t t-set="o" t-value="doc"/>
        <t t-set="report" t-value="doc"/>
        <t t-set="base_url" t-value="request.env['ir.config_parameter'].sudo().get_param('web.base.url')"/>
        <div class="header" style="margin: 0 auto; text-align: left;">
            <img t-att-src="'/grnlnd_task/static/src/img/header.png'" style="max-height: 100px; margin-top:25px; margin-left:5px;" />
        </div>
    </template>

    <template id="custom_invoice_header_template">
        <div class="header" style="top: 0; margin-bottom:-50px;">
            <img t-att-src="'/grnlnd_task/static/src/img/invoice_header.png'" style="width: 100%; max-height: 200px; margin-top:40px;" />
        </div>
    </template>

    <template id="custom_footer_template">
        <div class="footer" style="margin-bottom:-50px;">
            <img t-att-src="'/grnlnd_task/static/src/img/footer.png'" style="width: 100%; max-height: 250px;" />
            <div class="text-center">
                Page <span class="page"/> of <span class="topage"/>
            </div>
        </div>
    </template>
    <template id="custom_footer_template1">
        <div class="footer" style="margin-bottom: -50px;">
            <table style="width: 100%; table-layout: fixed; border: 1px solid white; border-collapse: collapse;">
                <tr style="border: 1px solid white;">
                    <td style="width: 33.33%; text-align: left; vertical-align: middle; border: 1px solid white;">
                        <img t-att-src="'/grnlnd_task/static/src/img/left_footer.png'" style="max-height: 80px; max-width: 100%;" />
                    </td>
                    <td style="width: 33.33%; text-align: center; vertical-align: middle; border: 1px solid white;">
                        <img t-att-src="'/grnlnd_task/static/src/img/middle_footer.png'" style="max-height: 80px; max-width: 100%;" />
                    </td>
                    <td style="width: 33.33%; text-align: right; vertical-align: middle; border: 1px solid white;">
                        <img t-att-src="'/grnlnd_task/static/src/img/right_footer.png'" style="max-height: 80px; max-width: 100%;" />
                    </td>
                </tr>
            </table>
            <div class="text-center" style="margin-top: 10px;">
                Page <span class="page"/> of <span class="topage"/>
            </div>
        </div>
    </template>
</odoo>

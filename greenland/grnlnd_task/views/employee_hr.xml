<odoo>
    <record id="view_employee_form_inherit_hourly_cost" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.hourly.cost</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_hourly_cost.view_employee_form"/>
        <field name="arch" type="xml">
            <group name="application_group" position="attributes">
                <attribute name="invisible">0</attribute>
            </group>
            <group name="application_group" position="inside">
                <div name="hourly_cost">
                    <field name="hourly_cost" class="oe_inline" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                </div>
            </group>
        </field>
    </record>
    <!-- Make Employee ID editable when empty, readonly when set -->
    <record id="view_employee_form_inherit_identification_id" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.identification.id</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='identification_id']" position="attributes">
                <attribute name="readonly">not id or identification_id</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>

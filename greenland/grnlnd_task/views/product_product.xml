<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_product_grnland_from" model="ir.ui.view">
        <field name="name">product.product.greenland.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']/h1" position="after">
                <field class="text-break" dir="rtl" style="text-align: right; font-size: 32px; font-weight: bold; color: #212529;" name="name_ar" options="{'line_breaks': False}" widget="text" placeholder="مثال على شاحنة شفط مياه الصرف الصحي"/>
            </xpath>
        </field>
    </record>
</odoo>
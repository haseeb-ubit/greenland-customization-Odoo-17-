<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_grnland_from" model="ir.ui.view">
                <field name="name">product.template.greenland.inherit</field>
                <field name="model">product.template</field>
                <field name="inherit_id" ref="product.product_template_only_form_view"/>
                <field name="arch" type="xml">
                    <xpath expr="//div[@name='options']" position="after">
                        <div name="grn_options">
                            <span class="d-inline-block">
                                <field name="non_hazardous" string="Non-Hazardous"/>
                                <label for="non_hazardous"/>
                            </span>
                            <span class="d-inline-block">
                                <field name="hazardous" string="Hazardous"/>
                                <label for="hazardous"/>
                            </span>
                        </div>
                    </xpath>
                    <xpath expr="//div[@class='oe_title']/h1" position="after">
                        <field class="text-break" dir="rtl" style="text-align: right; font-size: 32px; font-weight: bold; color: #212529;" name="name_ar" options="{'line_breaks': False}" widget="text" placeholder="مثال على شاحنة شفط مياه الصرف الصحي"/>
                    </xpath>
                </field>
            </record>
</odoo>
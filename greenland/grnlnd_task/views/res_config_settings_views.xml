<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_threshold" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.threshold</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Sales Threshold" string="Sales Threshold" name="sales_threshold">
                    <block title="Sales Threshold Configuration" name="threshold_config">
                        <setting string="Silver Range" help="Maximum amount for Silver">
                            <field name="silver_threshold"/>
                        </setting>
                        <setting string="Gold Range" help="Maximum amount for Gold">
                            <field name="gold_threshold"/>
                        </setting>
                        <setting string="Platinum Range" help="Minimum amount for Platinum">
                            <field name="platinum_threshold"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
<odoo>
    <data>
        <!-- Template to add driver-specific CSS classes -->
        <template id="driver_user_template" inherit_id="web.layout">
            <xpath expr="//body" position="attributes">
                <attribute name="t-att-class" add="'driver-user' if request.env.user.has_group('grnlnd_task.group_driver_access') else ''"/>
                <attribute name="t-att-data-driver-user" add="'true' if request.env.user.has_group('grnlnd_task.group_driver_access') else 'false'"/>
            </xpath>
        </template>
        

<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Inherited form view of account move -->
    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit.sales.contract.and.recurring.invoices</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="contract_origin" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='product_id']" position="attributes">
                <attribute name="domain">parent.move_type in ('out_invoice', 'out_refund', 'out_receipt') and [('sale_ok', '=', True)] or [('purchase_ok', '=', True)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="subscription_contracts_cancel_wizard_form" model="ir.ui.view">
        <field name="name">subscription.contracts.cancel.wizard.form</field>
        <field name="model">subscription.contracts.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Cancellation">
                <group>
                    <field name="contract_id" invisible="1"/>
                    <div style="white-space: nowrap; font-weight: bold; margin: 10px 0;">
                        Are you sure you want to cancel this contract?
                    </div>
                </group>
                <footer>
                    <button name="action_confirm_cancel" string="Confirm" type="object" class="btn-primary"/>
                    <button name="action_abort" string="Cancel" type="object" class="btn-secondary"/>
                </footer>
            </form>

        </field>
    </record>

    <record id="action_subscription_contracts_cancel_wizard" model="ir.actions.act_window">
        <field name="name">Confirm Cancellation</field>
        <field name="res_model">subscription.contracts.cancel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>